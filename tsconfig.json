{
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"target": "es2020",
		"module": "es2020",
		"moduleResolution": "bundler",
		"lib": ["es2020", "dom"],
		"declaration": false,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": [
		"core/**/*.ts",
		"content/**/*.ts",
		"ui/**/*.ts",
		"main.ts"
	],
	"exclude": [
		"parts/**/*.ts",
		"node_modules"
	]
}
